{
  "$schema": "https://openclaw.ai/schemas/openclaw.json",
  "gateway": {
    "port": 2090,
    "mode": "local",
    "auth": {
      "mode": "none"
    },
    "controlUi": {
      "enabled": false,
      "basePath": "/openclaw",
      "dangerouslyDisableDeviceAuth": true
    }
  },
  "agents": {
    "defaults": {
      "workspace": "~/AcaClaw",
      "sandbox": {
        "mode": "all",
        "scope": "session",
        "workspaceAccess": "rw"
      },
      "compaction": {
        "notifyUser": false
      },
      "params": {}
    }
  },
  "tools": {
    "fs": {
      "workspaceOnly": true
    },
    "exec": {
      "applyPatch": {
        "workspaceOnly": true
      },
      "pathPrepend": ["~/.acaclaw/miniforge3/bin"],
      "security": "full",
      "ask": "always"
    },
    "deny": [
      "gateway",
      "cron",
      "sessions_spawn",
      "sessions_send",
      "mcp_install",
      "mcp_uninstall",
      "config_set"
    ],
    "elevated": {
      "enabled": false
    }
  },
  "models": {
    "providers": {
      "modelstudio": {
        "baseUrl": "https://dashscope.aliyuncs.com/compatible-mode/v1",
        "models": []
      }
    }
  },
  "plugins": {
    "allow": [
      "acaclaw-academic-env",
      "acaclaw-backup",
      "acaclaw-compat-checker",
      "acaclaw-logger",
      "acaclaw-security",
      "acaclaw-ui",
      "acaclaw-workspace"
    ]
  }
}
