{
  "$schema": "https://openclaw.ai/schemas/openclaw.json",
  "gateway": {
    "port": 2090,
    "mode": "local",
    "auth": {
      "mode": "none"
    },
    "controlUi": {
      "enabled": true,
      "basePath": "/openclaw",
      "dangerouslyDisableDeviceAuth": true
    }
  },
  "agents": {
    "defaults": {
      "workspace": "~/AcaClaw",
      "thinkingDefault": "adaptive",
      "sandbox": {
        "mode": "off"
      },
      "compaction": {
        "notifyUser": false
      },
      "params": {},
      "model": "modelstudio/qwen3.5-plus"
    },
    "list": [
      {
        "id": "main",
        "name": "Aca",
        "default": true,
        "workspace": "~/AcaClaw",
        "reasoningDefault": "stream",
        "identity": {
          "name": "Aca",
          "emoji": "🎓"
        }
      },
      {
        "id": "biologist",
        "name": "Dr. Gene",
        "workspace": "~/AcaClaw/agents/biologist",
        "reasoningDefault": "stream",
        "identity": {
          "name": "Dr. Gene",
          "emoji": "🧬"
        }
      },
      {
        "id": "medscientist",
        "name": "Dr. Curie",
        "workspace": "~/AcaClaw/agents/medscientist",
        "reasoningDefault": "stream",
        "identity": {
          "name": "Dr. Curie",
          "emoji": "🏥"
        }
      },
      {
        "id": "ai-researcher",
        "name": "Dr. Turing",
        "workspace": "~/AcaClaw/agents/ai-researcher",
        "reasoningDefault": "stream",
        "identity": {
          "name": "Dr. Turing",
          "emoji": "🤖"
        }
      },
      {
        "id": "data-analyst",
        "name": "Dr. Bayes",
        "workspace": "~/AcaClaw/agents/data-analyst",
        "reasoningDefault": "stream",
        "identity": {
          "name": "Dr. Bayes",
          "emoji": "📊"
        }
      },
      {
        "id": "cs-scientist",
        "name": "Dr. Knuth",
        "workspace": "~/AcaClaw/agents/cs-scientist",
        "reasoningDefault": "stream",
        "identity": {
          "name": "Dr. Knuth",
          "emoji": "💻"
        }
      }
    ]
  },
  "tools": {
    "fs": {
      "workspaceOnly": true
    },
    "exec": {
      "applyPatch": {
        "workspaceOnly": true
      },
      "pathPrepend": [
        "~/.acaclaw/miniforge3/bin"
      ],
      "security": "full",
      "ask": "always"
    },
    "deny": [
      "gateway",
      "cron",
      "sessions_spawn",
      "sessions_send",
      "mcp_install",
      "mcp_uninstall",
      "config_set",
      "canvas",
      "nodes",
      "agents_list",
      "sessions_list",
      "sessions_history",
      "subagents",
      "sessions_yield",
      "tts",
      "backup_list",
      "backup_restore",
      "compat_check",
      "env_status",
      "event_log",
      "security_audit",
      "security_status"
    ]
  },
  "models": {
    "providers": {
      "modelstudio": {
        "baseUrl": "https://dashscope.aliyuncs.com/compatible-mode/v1",
        "models": []
      }
    }
  },
  "plugins": {
    "allow": [
      "acaclaw-academic-env",
      "acaclaw-backup",
      "acaclaw-compat-checker",
      "acaclaw-logger",
      "acaclaw-security",
      "acaclaw-ui",
      "acaclaw-workspace"
    ]
  }
}
