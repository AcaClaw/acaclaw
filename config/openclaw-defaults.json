{
  "$schema": "https://openclaw.ai/schemas/openclaw.json",
  "gateway": {
    "port": 2090,
    "mode": "local",
    "controlUi": {
      "enabled": false,
      "basePath": "/",
      "dangerouslyDisableDeviceAuth": true
    }
  },
  "agents": {
    "defaults": {
      "workspace": "~/AcaClaw",
      "thinkingDefault": "adaptive",
      "sandbox": {
        "mode": "off"
      }
    },
    "list": [
      {
        "id": "main",
        "name": "Aca",
        "default": true,
        "workspace": "~/AcaClaw",
        "identity": { "name": "Aca", "emoji": "🎓" },
        "tools": {
          "deny": ["gateway", "cron", "mcp_install", "mcp_uninstall", "config_set"]
        }
      },
      {
        "id": "biologist",
        "name": "Dr. Gene",
        "workspace": "~/AcaClaw/agents/biologist",
        "identity": { "name": "Dr. Gene", "emoji": "🧬" },
        "tools": {
          "deny": ["gateway", "cron", "mcp_install", "mcp_uninstall", "config_set"]
        }
      },
      {
        "id": "medscientist",
        "name": "Dr. Curie",
        "workspace": "~/AcaClaw/agents/medscientist",
        "identity": { "name": "Dr. Curie", "emoji": "🏥" },
        "tools": {
          "deny": ["gateway", "cron", "mcp_install", "mcp_uninstall", "config_set"]
        }
      },
      {
        "id": "ai-researcher",
        "name": "Dr. Turing",
        "workspace": "~/AcaClaw/agents/ai-researcher",
        "identity": { "name": "Dr. Turing", "emoji": "🤖" },
        "tools": {
          "deny": ["gateway", "cron", "mcp_install", "mcp_uninstall", "config_set"]
        }
      },
      {
        "id": "data-analyst",
        "name": "Dr. Bayes",
        "workspace": "~/AcaClaw/agents/data-analyst",
        "identity": { "name": "Dr. Bayes", "emoji": "📊" },
        "tools": {
          "deny": ["gateway", "cron", "mcp_install", "mcp_uninstall", "config_set"]
        }
      },
      {
        "id": "cs-scientist",
        "name": "Dr. Knuth",
        "workspace": "~/AcaClaw/agents/cs-scientist",
        "identity": { "name": "Dr. Knuth", "emoji": "💻" },
        "tools": {
          "deny": ["gateway", "cron", "mcp_install", "mcp_uninstall", "config_set"]
        }
      }
    ]
  },
  "tools": {
    "fs": {
      "workspaceOnly": true
    },
    "exec": {
      "applyPatch": {
        "workspaceOnly": true
      },
      "pathPrepend": ["~/.acaclaw/miniforge3/bin"]
    },
    "deny": [
      "gateway",
      "cron",
      "sessions_spawn",
      "sessions_send",
      "mcp_install",
      "mcp_uninstall",
      "config_set"
    ]
  }
}
