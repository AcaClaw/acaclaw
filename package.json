{
  "name": "@acaclaw/acaclaw",
  "version": "0.1.2",
  "description": "Academic distribution of OpenClaw — AI-powered academic assistant",
  "type": "module",
  "license": "MIT",
  "author": "Cosinx AI",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/acaclaw/acaclaw.git"
  },
  "files": [
    "plugins/",
    "config/",
    "env/",
    "agents/",
    "scripts/",
    "ui/dist/",
    "public/logo/",
    "skills.json"
  ],
  "bin": {
    "acaclaw-install": "./scripts/install.sh",
    "acaclaw-start": "./scripts/start.sh",
    "acaclaw-stop": "./scripts/stop.sh"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "build:ui": "cd ui && npm install --no-audit --no-fund && npm run build",
    "prepare": "npm run build:ui",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npx playwright test",
    "test:e2e:update": "npx playwright test --update-snapshots",
    "test:e2e:ui": "npx playwright test --ui",
    "deploy": "cd ui && npx vite build && rsync -a --delete ../ui/dist/ ~/.openclaw/ui/",
    "check": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/mcp": "^0.0.68",
    "@playwright/test": "^1.59.0",
    "@sinclair/typebox": "0.34.48",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.2.4",
    "happy-dom": "^20.8.7",
    "lit": "^3.3.2",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "ws": "^8.20.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.2"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  }
}
